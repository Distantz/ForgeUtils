{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            // This builds all ovls, including inner UI packages.
            "name": "Run Build",
            "type": "debugpy",
            "request": "launch",
            "program": "./Build/build.py",
            "args": [
                "${env:COBRATOOLS}",
                "./Manifest.xml"
            ],
            "console": "integratedTerminal",
        },
        {
            // This builds all ovls, including inner UI packages, then launches the game through Steam.
            "name": "Run Build and Launch",
            "type": "debugpy",
            "request": "launch",
            "program": "./Build/build.py",
            "args": [
                "${env:COBRATOOLS}",
                "./Manifest.xml",
                "-launch"
            ],
            "console": "integratedTerminal",
        },
        {
            // This packages all NEEDED files into a zip.
            "name": "Package Build",
            "type": "debugpy",
            "request": "launch",
            "program": "./Build/package.py",
            "args": [
                ".",
                "${workspaceFolderBasename}.zip"
            ],
            "console": "integratedTerminal",
        },
        {
            // This rebuilds the SQL bindings based on input FDBs.
            "name": "Run SQL rebuild",
            "type": "debugpy",
            "request": "launch",
            "program": "./SQLBindingGeneration/main.py",
            "console": "integratedTerminal",
        }
    ]
}